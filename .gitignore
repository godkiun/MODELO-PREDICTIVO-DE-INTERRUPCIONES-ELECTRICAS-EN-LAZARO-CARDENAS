# Dependencias de Node.js
**/node_modules/
**/.next/
**/out/
**/build/

# Archivos compilados de Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Base de datos (SQLite)
# Las bases de datos locales suelen cambiar constantemente y ser pesadas.
# Se ignoran para que cada clon inicialice su base de datos.
**/*.db
**/*.sqlite3

# Modelos entrenados (Pickle)
# Se ignoran porque son binarios pesados que pueden reconstruirse
# ejecutando los scripts de entrenamiento (crear_dataset.py y entrenar_modelo_zonal.py).
**/*.pkl

# Entorno Virtual de Python
.venv/
venv/
env/
ENV/

# Variables de Entorno y Configuración Sensible
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Archivos del Sistema Operativo
**/.DS_Store
**/Thumbs.db
**/*.pem

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Configuraciones de editores
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
commits.txt
